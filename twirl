function twirl
{
    TCOUNT=0

    while :
    do
        (( TCOUNT = TCOUNT + 1 ))

        case $TCOUNT in
            1) printf "-\b" ;;
            2) printf "\\\b" ;;
            3) printf "|\b" ;;
            4) printf "/\b" ;;
            *) TCOUNT=0 ;;
        esac

        sleep 0.2
    done
}
